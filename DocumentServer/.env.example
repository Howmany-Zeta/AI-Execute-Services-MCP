# 复制为 .env 后按需修改: cp .env.example .env

# 预构建镜像（默认：GCP Artifact Registry）
DOCUMENTSERVER_IMAGE=us-central1-docker.pkg.dev/ca-biz-kjmsdw-y59m/aiecs-mcp-servers/aiecs-documentserver:latest

# 宿主机端口（避免与本机 80 冲突）
DS_HTTP_PORT=8080
DS_HTTPS_PORT=8443

JWT_ENABLED=true
JWT_SECRET=your-jwt-secret-change-me
