# AIECS-MCP 一键部署环境变量
# 复制为 .env 并修改: cp .env.example .env

# ========== Redis（必填）==========
REDIS_PASSWORD=your-redis-password-change-me

# ========== DocumentServer / ONLYOFFICE（必填）==========
# 预构建镜像（与 DocumentServer/docker-compose 默认一致；需能拉取 GCP Artifact Registry）
DOCUMENTSERVER_IMAGE=us-central1-docker.pkg.dev/ca-biz-kjmsdw-y59m/aiecs-mcp-servers/aiecs-documentserver:latest

JWT_SECRET=your-jwt-secret-change-me
POSTGRES_PASSWORD=your-pg-password-change-me
RABBITMQ_USER=onlyoffice
RABBITMQ_PASSWORD=your-rmq-password-change-me

# MCP 服务用容器名访问 DocumentServer（同一 aiecs-network）
# DOCUMENTSERVER_URL=http://documentserver:80

# ========== PPT-Tool AI 配置 ==========
# 可选: vertex | gemini | openai
AI_PROVIDER_FORMAT=gemini
GOOGLE_API_KEY=
# Vertex AI 时使用:
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ========== API-Tool 外部 API Keys（可选）==========
# FRED_API_KEY=
# NEWSAPI_API_KEY=
# ALPHAVANTAGE_API_KEY=
# OPENWEATHERMAP_API_KEY=
# SECEDGAR_API_KEY=
# ...
